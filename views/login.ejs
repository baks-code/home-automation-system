<!DOCTYPE html>

<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Login | InteliSec</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-primary": "#ffffff",
                        "surface-dim": "#0a0a0c",
                        "surface-container-highest": "#33353f",
                        "background": "#050507",
                        "on-surface": "#f1f1f1",
                        "secondary-fixed": "#3e3e42",
                        "on-surface-variant": "#a1a3af",
                        "surface-container-high": "#282a33",
                        "surface-bright": "#1c1d24",
                        "tertiary": "#8e9092",
                        "primary": "#2962ff",
                        "on-error-container": "#ffdad6",
                        "secondary": "#919194",
                        "inverse-surface": "#f1f1f1",
                        "outline": "#8c8e9d",
                        "on-secondary-fixed-variant": "#c7c6c6",
                        "tertiary-fixed": "#474747",
                        "outline-variant": "#434656",
                        "on-background": "#f1f1f1",
                        "on-error": "#690005",
                        "error": "#ffb4ab",
                        "inverse-on-surface": "#1a1c1c",
                        "surface": "#050507",
                        "primary-fixed": "#dce1ff",
                        "surface-variant": "#434656",
                        "tertiary-fixed-dim": "#464747",
                        "on-tertiary": "#2d2f31",
                        "on-primary-fixed": "#001550",
                        "on-tertiary-fixed-variant": "#c7c6c6",
                        "on-tertiary-fixed": "#e3e2e2",
                        "surface-container": "#1c1d24",
                        "inverse-primary": "#0049db",
                        "tertiary-container": "#464747",
                        "on-primary-fixed-variant": "#003ab3",
                        "on-primary-container": "#dce1ff",
                        "surface-container-low": "#111218",
                        "secondary-container": "#47474a",
                        "primary-fixed-dim": "#b6c4ff",
                        "primary-container": "#2962ff",
                        "error-container": "#93000a",
                        "on-secondary-fixed": "#f1f1f1",
                        "on-secondary-container": "#e4e2e1",
                        "on-tertiary-container": "#e3e2e2",
                        "secondary-fixed-dim": "#47474a",
                        "surface-container-lowest": "#050507",
                        "surface-tint": "#2962ff",
                        "on-secondary": "#1a1c1c"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Inter"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-panel {
            background: rgba(28, 29, 36, 0.4);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            border-left: 1px solid rgba(255, 255, 255, 0.05);
        }

        .bg-mesh {
            background-color: #050507;
            background-image:
                radial-gradient(at 0% 0%, rgba(41, 98, 255, 0.08) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(41, 98, 255, 0.12) 0px, transparent 50%),
                radial-gradient(at 100% 0%, rgba(182, 196, 255, 0.05) 0px, transparent 50%);
        }
    </style>
</head>

<body class="bg-mesh font-body min-h-screen flex flex-col selection:bg-primary/30 selection:text-white">
    <main class="flex-grow flex items-center justify-center p-6 md:p-12 relative overflow-hidden">
        <div class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] left-[-5%] w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px]"></div>
        <div class="w-full max-w-md z-10">
            <div class="mb-12 text-center">
                <div
                    class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary mb-6 shadow-[0_20px_40px_rgba(41,98,255,0.3)]">
                    <span class="material-symbols-outlined text-on-primary text-3xl" data-weight="fill">shield</span>
                </div>
                <h1 class="text-4xl font-extrabold tracking-tighter text-on-surface mb-2">InteliSec</h1>
                <p class="text-on-surface-variant text-sm font-medium tracking-wide">SECURE ACCESS TO YOUR HOME</p>
            </div>
            <div
                class="glass-panel rounded-[2rem] p-8 md:p-10 shadow-[0_40px_80px_rgba(0,0,0,0.5)] border border-white/5">
                <form method="POST" action="/login" class="space-y-6">
                    <div>
                        <label
                            class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2 px-1"
                            for="username">Username</label>
                        <div class="relative group">
                            <div
                                class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-outline group-focus-within:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[20px]">person</span>
                            </div>
                            <input
                                class="w-full bg-surface-container-low border border-white/5 rounded-xl py-4 pl-12 pr-4 text-on-surface placeholder:text-outline/40 focus:ring-2 focus:ring-primary/40 focus:bg-surface-bright focus:border-primary/50 transition-all duration-300"
                                id="username" name="username" placeholder="Enter username" type="text" required/>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between items-center mb-2 px-1">
                            <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest"
                                for="password">Password</label>
                        </div>
                        <div class="relative group">
                            <div
                                class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-outline group-focus-within:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[20px]">lock</span>
                            </div>
                            <input
                                class="w-full bg-surface-container-low border border-white/5 rounded-xl py-4 pl-12 pr-4 text-on-surface placeholder:text-outline/40 focus:ring-2 focus:ring-primary/40 focus:bg-surface-bright focus:border-primary/50 transition-all duration-300"
                                id="password" name="password" placeholder="••••••••" type="password" required/>
                        </div>
                    </div>
                    <button
                        class="w-full py-4 bg-[#2962FF] text-white rounded-xl font-bold text-sm uppercase tracking-widest shadow-[0_10px_20px_rgba(41,98,255,0.3)] hover:shadow-[0_15px_30px_rgba(41,98,255,0.5)] hover:-translate-y-0.5 transition-all duration-300 active:scale-[0.98]"
                        type="submit">
                        Login
                    </button>
                </form>
            </div>
            <div class="mt-12 flex justify-center space-x-8">
                <div
                    class="flex items-center space-x-2 grayscale opacity-40 hover:opacity-80 transition-opacity cursor-default">
                    <span class="material-symbols-outlined text-sm">verified_user</span>
                    <span class="text-[10px] font-black uppercase tracking-widest">Encrypted</span>
                </div>
                <div
                    class="flex items-center space-x-2 grayscale opacity-40 hover:opacity-80 transition-opacity cursor-default">
                    <span class="material-symbols-outlined text-sm">fingerprint</span>
                    <span class="text-[10px] font-black uppercase tracking-widest">Biometric Ready</span>
                </div>
            </div>
        </div>
    </main>
    <footer class="p-8 text-center">
        <p class="text-[10px] font-medium text-outline uppercase tracking-[0.2em] opacity-60">© 2026 InteliSec. All Rights Reserved.</p>
    </footer>
</body>

</html>

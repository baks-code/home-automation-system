  <script>

    $(document).ready(function () {
      // 2. Initialize the DataTable
      $('#eventTable').DataTable({
        "order": [[0, "desc"]], // Show newest ID first
        "pageLength": 10          // Show 10 rows at a time
      });
    });

    function openModal(type, location, time, imgSrc) {
      const modal = document.getElementById('imageModal');
      document.getElementById('modalImage').src = imgSrc;
      document.getElementById('modalTitle').innerText = type;
      document.getElementById('modalDetails').innerText = `${location} • Detected at ${time}`;
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      document.getElementById('imageModal').classList.add('hidden');
      document.body.style.overflow = 'auto';
    }

    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    document.getElementById('imageModal').addEventListener('click', closeModal);
  </script>


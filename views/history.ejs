  <!-- Image Modal -->
  <div class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-surface-dim/80 backdrop-blur-sm"
    id="imageModal">
    <div
      class="obsidian-card max-w-4xl w-full rounded-[2.5rem] overflow-hidden relative shadow-[0_40px_80px_rgba(0,0,0,0.6)]"
      onclick="event.stopPropagation()">
      <button
        class="absolute top-6 right-6 z-10 w-10 h-10 rounded-full glass-panel flex items-center justify-center text-on-surface hover:bg-white/15 transition-colors"
        onclick="closeModal()">
        <span class="material-symbols-outlined">close</span>
      </button>
      <div class="p-2">
        <img alt="Snapshot" class="w-full aspect-video object-cover rounded-[2rem]" id="modalImage" />
      </div>
      <div class="p-8">
        <div class="flex justify-between items-end">
          <div>
            <h2 class="text-2xl font-bold text-on-surface mb-1" id="modalTitle">Event Snapshot</h2>
            <p class="text-on-surface-variant" id="modalDetails"></p>
          </div>
          <button
            class="bg-primary text-on-primary px-6 py-3 rounded-xl text-xs font-bold uppercase tracking-widest shadow-[0_8px_20px_rgba(41,98,255,0.3)] hover:shadow-[0_12px_28px_rgba(41,98,255,0.45)] hover:-translate-y-0.5 transition-all duration-300">
            Download Snapshot
          </button>
        </div>
      </div>
    </div>

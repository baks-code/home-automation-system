      <!-- Latest Motion Capture -->
      <section class="mb-12">
        <h2 class="text-[10px] font-bold text-primary uppercase tracking-[0.2em] mb-4">Latest Motion Capture</h2>

        <% // 1. Loop through 'events' and find the first one that has a URL const latestWithImage=events.find(e=> e.url
          && e.url !== 'null' && e.url !== '');
          %>

          <% if (latestWithImage) { %>
            <div class="relative overflow-hidden rounded-[2rem] obsidian-card group">
              <div class="aspect-[21/9] w-full relative">
                <img alt="Latest motion capture"
                  class="w-full h-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105"
                  src="<%= latestWithImage.url %>" />

                <div class="absolute inset-0 bg-gradient-to-t from-surface-dim/90 via-transparent to-transparent"></div>

                <div class="absolute top-6 left-6 glass-panel px-3 py-1.5 rounded-full flex items-center space-x-2">
                  <span
                    class="w-2 h-2 rounded-full bg-error animate-pulse shadow-[0_0_8px_rgba(255,180,171,0.8)]"></span>
                  <span class="text-[10px] font-black uppercase tracking-widest text-on-surface">Live</span>
                </div>

                <div class="absolute bottom-6 left-8">
                  <h3 class="text-2xl font-bold text-on-surface">
                    <%= latestWithImage.event_type %>
                  </h3>
                  <p class="text-on-surface-variant text-sm mt-1">Main Driveway • <%= latestWithImage.timestamp %>
                  </p>
                </div>
              </div>
            </div>
            <% } else { %>
              <!-- Fallback if no images are found in the list -->
              <div class="rounded-[2rem] obsidian-card p-12 text-center border border-white/5 opacity-40">
                <p class="text-on-surface-variant text-sm italic">No image captures found in recent history.</p>
              </div>
              <% } %>
      </section>

      <!-- History Log -->
